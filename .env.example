# McNutt's Island Alliance — Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Session secret — generate a long random string for production
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Admin panel
# The admin password is set on first run via ADMIN_PASSWORD below.
# After the first run, change this or leave blank — the hash is stored in the database.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Email (SMTP) — the site owner will provide production credentials
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@mcnuttsisland.org
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=McNutt's Island Alliance
SMTP_FROM_EMAIL=noreply@mcnuttsisland.org

# Site URL (no trailing slash)
SITE_URL=https://mcnuttsisland.org

# Database path (relative to project root)
DB_PATH=./database/mcnutts.db
