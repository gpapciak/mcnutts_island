<svg class="svg-icon svg-icon--seal" viewBox="0 0 48 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- Harbour seal — head bobbing above water, whiskers, round eyes -->
  <!-- Water line -->
  <path d="M4,26 C10,23 18,27 24,24 C30,21 38,25 44,23" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
  <!-- Body (partially submerged) -->
  <ellipse cx="24" cy="28" rx="11" ry="5" stroke="currentColor" stroke-width="1.2"/>
  <!-- Neck -->
  <path d="M20,24 C20,21 22,20 24,20 C26,20 28,21 28,24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Head — round -->
  <circle cx="24" cy="17" r="6" stroke="currentColor" stroke-width="1.3"/>
  <!-- Eyes -->
  <circle cx="21.5" cy="15.5" r="1.2" stroke="currentColor" stroke-width="1"/>
  <circle cx="26.5" cy="15.5" r="1.2" stroke="currentColor" stroke-width="1"/>
  <!-- Nose -->
  <path d="M23,18.5 Q24,19.5 25,18.5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <!-- Whiskers -->
  <path d="M18,18 L13,17.5 M18,19 L13,19.5 M30,18 L35,17.5 M30,19 L35,19.5" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
  <!-- Flipper hint -->
  <path d="M33,29 Q38,27 40,30 Q37,32 33,31" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
