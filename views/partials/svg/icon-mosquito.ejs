  <!-- Antenna -->
  <path d="M22.5,15 C21,12 20,9 21,7" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
  <path d="M25.5,15 C27,12 28,9 27,7" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
