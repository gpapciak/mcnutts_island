  <circle cx="24" cy="17" r="2.5" stroke="currentColor" stroke-width="1.2"/>
  <!-- Compound eye (big — slightly funny) -->
  <circle cx="25.5" cy="16" r="1.5" stroke="currentColor" stroke-width="1"/>
  <!-- Proboscis — comically long and slightly drooping -->
  <path d="M24,19 C24,22 23,25 22,28 C21.5,30 22,31.5 23,31" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
  <!-- Legs — 3 per side, spindly -->
