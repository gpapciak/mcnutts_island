<svg class="svg-icon svg-icon--mosquito" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- Mosquito — slightly humorous, exaggerated proboscis, striped abdomen -->
  <!-- Wings (translucent suggestion — two pairs) -->
  <path d="M24,20 C20,14 12,10 8,13 C12,16 18,18 22,20" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
  <path d="M24,20 C28,14 36,10 40,13 C36,16 30,18 26,20" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.7"/>
  <path d="M24,22 C19,18 11,17 8,20 C12,21 18,21 22,22" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.5"/>
  <path d="M24,22 C29,18 37,17 40,20 C36,21 30,21 26,22" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.5"/>
  <!-- Thorax — small round -->
  <circle cx="24" cy="21" r="3.5" stroke="currentColor" stroke-width="1.2"/>
  <!-- Abdomen — elongated, striped -->
  <path d="M22,24 C21,28 21,33 23,37 C24,39 25,39 25,37 C27,33 27,28 26,24" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
