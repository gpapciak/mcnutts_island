<svg class="svg-icon svg-icon--osprey" viewBox="0 0 48 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- Osprey diving/hovering — kinked wings, visible talons, fish suggestion -->
  <!-- Body — torpedo shape, angled dive -->
  <ellipse cx="26" cy="18" rx="6" ry="3" stroke="currentColor" stroke-width="1.3" transform="rotate(-15, 26, 18)"/>
  <!-- Head — white cap -->
  <circle cx="30.5" cy="13" r="3" stroke="currentColor" stroke-width="1.2"/>
  <!-- Hooked beak -->
  <path d="M33,12.5 L36,13.5 L33.5,14.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Eye stripe -->
  <path d="M29,12.5 L33,12.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Eye -->
  <circle cx="30" cy="12" r="0.9" stroke="currentColor" stroke-width="0.9"/>
  <!-- Left wing — kinked at wrist (osprey characteristic) -->
  <path d="M22,17 C18,13 12,8 6,7 C9,10 13,13 15,16 C11,14 6,13 3,14 C7,15 11,16 14,18 C10,17 6,18 4,20 C8,19 12,18 15,19" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Right wing — kinked -->
  <path d="M30,17 C34,14 38,10 44,9 C41,12 38,14 36,17 C40,15 44,14 46,15 C42,16 39,17 36,18 C39,18 43,19 45,21 C41,19 38,18 35,19" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Tail — squared (osprey style) -->
  <path d="M20,20 L17,27 M22,21 L20,28 M24,22 L24,29 M26,21 L28,28" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <!-- Talons reaching down -->
  <path d="M24,22 L22,28 L20,31 M24,22 L24,29 L22,32 M24,22 L26,29 L28,31" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <!-- Fish (caught or targeted) — simple arc below -->
  <path d="M18,33 Q24,30 30,33 Q24,36 18,33" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"/>
</svg>
