<svg class="svg-icon svg-icon--songbird" viewBox="0 0 48 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <!-- Small songbird perched on a twig — side profile -->
  <!-- Twig -->
  <path d="M8,28 L40,28" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  <!-- Feet/perch -->
  <path d="M22,28 L20,32 M22,28 L22,32 M22,28 L24,32 M28,28 L26,32 M28,28 L28,32 M28,28 L30,32" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
  <!-- Body — plump oval -->
  <ellipse cx="25" cy="21" rx="8" ry="6" stroke="currentColor" stroke-width="1.3"/>
  <!-- Head -->
  <circle cx="31" cy="15" r="4.5" stroke="currentColor" stroke-width="1.3"/>
  <!-- Beak -->
  <path d="M34.5,14.5 L38,14 L34.5,15.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
  <!-- Eye -->
  <circle cx="32.5" cy="13.5" r="1" stroke="currentColor" stroke-width="1"/>
  <!-- Wing detail -->
  <path d="M18,20 Q22,17 30,18" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <path d="M17,22 Q21,20 29,21" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.6"/>
  <!-- Tail -->
  <path d="M17,22 L11,24 M17,23 L10,26 M17,24 L12,28" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <!-- Song notes -->
  <path d="M36,8 Q37,6 39,7" stroke="currentColor" stroke-width="1" stroke-linecap="round"/>
  <path d="M39,5 Q41,3 43,4" stroke="currentColor" stroke-width="0.9" stroke-linecap="round"/>
</svg>
