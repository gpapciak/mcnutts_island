<!-- McNutt's Island lighthouse — detailed elevation sketch -->
<svg class="svg-illustration svg-illustration--sm svg-illustration--center" viewBox="0 0 200 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  <!-- Ground / headland -->
  <path d="M10,305 Q60,295 100,298 Q140,301 190,292" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
  <path d="M40,305 Q70,299 100,302 Q130,305 160,300" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.2"/>

  <!-- Keeper's dwelling — to the right -->
  <rect x="118" y="240" width="52" height="42" rx="1" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <!-- Dwelling roof -->
  <path d="M115,240 L144,222 L173,240" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>
  <!-- Dwelling windows -->
  <rect x="125" y="252" width="10" height="10" rx="0.5" stroke="currentColor" stroke-width="0.9" opacity="0.35"/>
  <rect x="143" y="252" width="10" height="10" rx="0.5" stroke="currentColor" stroke-width="0.9" opacity="0.35"/>
  <!-- Dwelling door -->
  <path d="M151,282 L151,270 Q151,267 154,267 L160,267 Q163,267 163,270 L163,282" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.35"/>
  <!-- Chimney -->
  <rect x="155" y="218" width="6" height="12" stroke="currentColor" stroke-width="0.9" opacity="0.3"/>

  <!-- Foundation platform -->
  <path d="M62,296 L62,288 L134,288 L134,296" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" opacity="0.55"/>

  <!-- Tower body — octagonal, tapered (wider at base) -->
  <path d="M72,288 L128,288 L118,140 L82,140 Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
  <!-- Tower horizontal band stripes (classic lighthouse) -->
  <path d="M74,268 L126,268 M76,248 L124,248 M78,228 L122,228 M80,208 L120,208 M82,188 L118,188 M84,168 L116,168" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.25"/>
  <!-- Tower corner edges (octagonal face lines) -->
  <path d="M80,288 L73,140 M120,288 L127,140" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.2"/>

  <!-- Gallery / railing ledge -->
  <rect x="76" y="136" width="48" height="6" rx="0.5" stroke="currentColor" stroke-width="1.2" opacity="0.6"/>
  <!-- Railing spindles -->
  <path d="M82,136 L82,126 M88,136 L88,124 M94,136 L94,124 M100,136 L100,124 M106,136 L106,124 M112,136 L112,124 M118,136 L118,126" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.4"/>
  <!-- Railing top rail -->
  <path d="M80,124 L120,124" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.45"/>

  <!-- Lantern room — octagonal glass house -->
  <rect x="82" y="100" width="36" height="24" rx="1" stroke="currentColor" stroke-width="1.3" opacity="0.7"/>
  <!-- Lantern room panes (vertical muntins) -->
  <path d="M91,100 L91,124 M100,100 L100,124 M109,100 L109,124 M118,100 L118,124" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.3"/>
  <!-- Horizontal muntin -->
  <path d="M82,112 L118,112" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.3"/>
  <!-- Light glow centre -->
  <circle cx="100" cy="112" r="6" stroke="currentColor" stroke-width="1" opacity="0.5"/>
  <circle cx="100" cy="112" r="3" stroke="currentColor" stroke-width="0.8" opacity="0.4"/>

  <!-- Cap / roof — conical -->
  <path d="M80,100 L120,100 L100,76 Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.65"/>
  <!-- Cap ball finial -->
  <circle cx="100" cy="74" r="3" stroke="currentColor" stroke-width="1" opacity="0.5"/>
  <!-- Lightning rod -->
  <path d="M100,71 L100,60" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.4"/>

  <!-- Light beam -->
  <path d="M118,106 L200,55 L200,72 Z" fill="currentColor" opacity="0.05" stroke="none"/>
  <path d="M118,109 L200,72 L200,88 Z" fill="currentColor" opacity="0.04" stroke="none"/>

  <!-- Fog alarm building — small, left of tower -->
  <rect x="30" y="262" width="38" height="28" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.35"/>
  <path d="M27,262 L49,248 L71,262" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round" opacity="0.35"/>
  <!-- Foghorn vent -->
  <path d="M60,255 L66,252 Q72,250 74,256 Q72,262 66,260 L60,258" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.3"/>

  <!-- Rocks at base -->
  <path d="M15,298 Q25,293 35,296 M165,295 Q175,291 185,294" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.25"/>

</svg>
