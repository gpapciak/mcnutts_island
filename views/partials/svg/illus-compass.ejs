<!-- Compass rose with HISTORY / FUTURE / JUSTICE / PLACE labels -->
<svg class="svg-illustration svg-illustration--md svg-illustration--center" viewBox="0 0 320 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  <!-- Outer circle -->
  <circle cx="160" cy="160" r="130" stroke="currentColor" stroke-width="1" opacity="0.25"/>
  <!-- Inner ring -->
  <circle cx="160" cy="160" r="90" stroke="currentColor" stroke-width="0.8" stroke-dasharray="4 6" opacity="0.2"/>
  <!-- Hub -->
  <circle cx="160" cy="160" r="12" stroke="currentColor" stroke-width="1.3" opacity="0.6"/>
  <circle cx="160" cy="160" r="4" stroke="currentColor" stroke-width="1" opacity="0.5"/>

  <!-- Cardinal points — elongated diamond needles -->
  <!-- North (top) -->
  <path d="M160,148 L155,110 L160,95 L165,110 Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" opacity="0.7"/>
  <!-- South (bottom) -->
  <path d="M160,172 L155,210 L160,225 L165,210 Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" opacity="0.55"/>
  <!-- West (left) -->
  <path d="M148,160 L110,155 L95,160 L110,165 Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" opacity="0.55"/>
  <!-- East (right) -->
  <path d="M172,160 L210,155 L225,160 L210,165 Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" opacity="0.7"/>

  <!-- Intercardinal tick marks -->
  <path d="M181,139 L200,120 M139,181 L120,200 M139,139 L120,120 M181,181 L200,200" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/>

  <!-- Decorative cross-hatch at intercardinals -->
  <path d="M181,139 L187,133 M181,181 L187,187 M139,139 L133,133 M139,181 L133,187" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.25"/>

  <!-- Labels — replacing N/S/E/W with thematic words -->
  <text x="160" y="76" text-anchor="middle" font-family="Georgia, serif" font-size="11" fill="currentColor" opacity="0.7" letter-spacing="0.08em">HISTORY</text>
  <text x="160" y="252" text-anchor="middle" font-family="Georgia, serif" font-size="11" fill="currentColor" opacity="0.6" letter-spacing="0.08em">FUTURE</text>
  <text x="70" y="164" text-anchor="middle" font-family="Georgia, serif" font-size="10" fill="currentColor" opacity="0.6" letter-spacing="0.06em">JUSTICE</text>
  <text x="250" y="164" text-anchor="middle" font-family="Georgia, serif" font-size="11" fill="currentColor" opacity="0.7" letter-spacing="0.08em">PLACE</text>

  <!-- Fine degree marks around outer ring -->
  <path d="M160,30 L160,38 M160,282 L160,290 M30,160 L38,160 M282,160 L290,160" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/>
  <path d="M251,69 L246,75 M69,251 L75,246 M69,69 L75,75 M251,251 L246,246" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.25"/>

</svg>
