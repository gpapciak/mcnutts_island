<!-- Mi'kmaq canoe on calm harbour water — birchbark style, paddle, distant shore -->
<svg class="svg-illustration svg-illustration--md svg-illustration--center" viewBox="0 0 400 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  <!-- Distant shoreline / island silhouette -->
  <path d="M0,90 Q30,82 60,85 Q90,78 110,70 Q130,62 150,65 Q170,68 190,60 Q210,52 230,56 Q250,60 270,55 Q290,50 310,54 Q340,60 370,65 Q390,68 400,65" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/>
  <!-- Distant treeline suggestion -->
  <path d="M110,70 L110,55 M130,65 L130,48 M150,65 L150,50 M170,60 L170,46 M190,60 L190,50 M210,55 L210,44 M230,56 L230,46 M250,60 L250,50 M270,55 L270,45" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.2"/>

  <!-- Harbour water surface -->
  <path d="M0,118 C60,110 140,124 220,114 C300,104 360,118 400,112 L400,200 L0,200 Z" fill="currentColor" opacity="0.05"/>
  <!-- Water lines / light chop -->
  <path d="M20,118 Q60,114 100,118 Q140,122 180,118 Q220,114 260,118 Q300,122 340,118 Q370,115 400,118" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.2"/>
  <path d="M0,128 Q50,124 110,128 Q170,132 230,127 Q290,122 350,126 Q380,128 400,126" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.15"/>
  <path d="M0,140 Q60,136 130,140 Q200,144 270,140 Q330,136 400,140" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.12"/>

  <!-- Canoe hull — elegant birchbark silhouette -->
  <path d="M100,125 Q130,108 200,106 Q270,104 300,120 Q290,138 200,140 Q110,142 100,125 Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>
  <!-- Canoe gunwale line (top rail) -->
  <path d="M102,122 Q140,112 200,110 Q260,108 298,122" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.45"/>
  <!-- Canoe ribs (internal frame showing through birchbark) -->
  <path d="M140,140 Q142,128 140,118 M160,141 Q162,128 160,110 M180,141 Q182,126 180,110 M200,141 Q200,126 200,110 M220,141 Q218,126 220,110 M240,140 Q238,126 240,112 M260,139 Q258,128 260,118" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.3"/>
  <!-- Canoe stem decoration (bow and stern curve) -->
  <path d="M100,124 Q96,118 104,112" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
  <path d="M300,120 Q306,114 298,108" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"/>

  <!-- Figure paddling — seated silhouette, forward third of canoe -->
  <!-- Body -->
  <ellipse cx="160" cy="116" rx="8" ry="5" stroke="currentColor" stroke-width="1.1" opacity="0.55"/>
  <!-- Head -->
  <circle cx="160" cy="110" r="5" stroke="currentColor" stroke-width="1.1" opacity="0.55"/>
  <!-- Paddle — reaching right -->
  <path d="M168,113 L195,105 L200,108 L198,114 L168,116" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
  <!-- Paddle blade -->
  <ellipse cx="198" cy="111" rx="6" ry="3.5" stroke="currentColor" stroke-width="1" transform="rotate(-30,198,111)" opacity="0.5"/>
  <!-- Left arm with paddle grip -->
  <path d="M155,113 L135,110" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.45"/>

  <!-- Second figure (further back) — smaller, paddling left side -->
  <circle cx="230" cy="115" r="4.5" stroke="currentColor" stroke-width="1" opacity="0.45"/>
  <ellipse cx="230" cy="120" rx="7" ry="4" stroke="currentColor" stroke-width="1" opacity="0.45"/>
  <!-- Paddle other side -->
  <path d="M222,118 L200,112 L198,116 L200,120 L222,122" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"/>

  <!-- Water reflection of canoe -->
  <path d="M110,142 Q160,148 200,146 Q250,144 295,138" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.12"/>

  <!-- Distant eagle silhouette -->
  <path d="M330,72 Q336,67 342,70 Q348,67 354,72" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/>

</svg>
