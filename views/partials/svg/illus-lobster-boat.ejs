  <circle cx="212" cy="118" r="4" stroke="currentColor" stroke-width="1" opacity="0.4"/>
  <circle cx="222" cy="115" r="3.5" stroke="currentColor" stroke-width="0.9" opacity="0.35"/>
  <path d="M212,122 L212,130 M222,118.5 L222,126" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.3"/>

  <!-- Mooring line to wharf -->
  <path d="M362,135 Q380,130 385,155" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.3"/>

  <!-- Reflection in water -->
  <path d="M160,172 Q156,180 152,188 M200,170 Q200,178 200,186" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.15"/>

  <!-- Gull on mast tip -->
  <path d="M148,58 Q152,54 156,57 Q160,54 164,58" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.4"/>

</svg>
