  <rect x="138" y="116" width="16" height="12" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.45"/>
  <rect x="160" y="116" width="16" height="12" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.45"/>
  <rect x="182" y="116" width="12" height="12" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.4"/>
