  <rect x="220" y="122" width="22" height="13" rx="1" stroke="currentColor" stroke-width="1" opacity="0.45"/>
  <rect x="245" y="122" width="22" height="13" rx="1" stroke="currentColor" stroke-width="1" opacity="0.45"/>
  <rect x="270" y="122" width="22" height="13" rx="1" stroke="currentColor" stroke-width="1" opacity="0.45"/>
