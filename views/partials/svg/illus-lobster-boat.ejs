  <path d="M231,122 L231,135 M242,122 L242,135 M256,122 L256,135 M267,122 L267,135 M281,122 L281,135 M292,122 L292,135" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" opacity="0.3"/>
  <!-- Row 2 (front, slightly lower) -->
  <rect x="228" y="133" width="20" height="12" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.4"/>
  <rect x="251" y="133" width="20" height="12" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.4"/>
  <rect x="274" y="133" width="20" height="12" rx="1" stroke="currentColor" stroke-width="0.9" opacity="0.4"/>
