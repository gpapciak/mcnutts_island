<!-- Sea kayak from above / slight angle — paddle, calm harbour water, wake -->
<svg class="svg-illustration svg-illustration--md svg-illustration--center" viewBox="0 0 380 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  <!-- Water surface -->
  <path d="M0,80 C60,72 140,86 220,76 C300,66 360,80 380,74 L380,180 L0,180 Z" fill="currentColor" opacity="0.05"/>
  <path d="M0,78 C40,72 100,82 160,75 C220,68 300,78 380,72" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.2"/>
  <path d="M0,90 C60,84 140,94 220,86 C300,78 360,88 380,84" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.15"/>
  <path d="M0,102 C70,97 160,106 240,99 C310,92 360,102 380,98" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.12"/>

  <!-- Wake / bow wave -->
  <path d="M186,96 Q170,104 148,108 M186,96 Q192,106 200,114" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.3"/>
  <path d="M180,98 Q160,108 135,114 M180,98 Q188,110 198,120" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.2"/>
  <!-- Stern wake -->
  <path d="M250,96 Q270,100 295,98 M250,96 Q265,102 285,104" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.2"/>

  <!-- Kayak hull — long, narrow, pointed ends, seen from slight above-angle -->
  <path d="M186,82 Q195,74 218,72 Q250,70 278,74 Q295,78 302,86 Q300,96 278,98 Q250,100 218,98 Q194,96 186,86 Q184,84 186,82 Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity="0.65"/>
  <!-- Kayak deck line (keel line) -->
  <path d="M186,84 Q218,80 244,80 Q270,80 302,86" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.35"/>
  <!-- Cockpit coaming -->
  <ellipse cx="240" cy="86" rx="22" ry="10" stroke="currentColor" stroke-width="1.1" opacity="0.55"/>
  <!-- Hatch front -->
  <ellipse cx="208" cy="82" rx="10" ry="5" stroke="currentColor" stroke-width="0.9" opacity="0.4"/>
  <!-- Hatch rear -->
  <ellipse cx="274" cy="86" rx="10" ry="5" stroke="currentColor" stroke-width="0.9" opacity="0.35"/>

  <!-- Paddler — seen from above, sitting in cockpit -->
  <!-- Torso -->
  <ellipse cx="240" cy="84" rx="8" ry="11" stroke="currentColor" stroke-width="1.1" opacity="0.55"/>
  <!-- Head -->
  <circle cx="240" cy="71" r="7" stroke="currentColor" stroke-width="1.1" opacity="0.55"/>
  <!-- Arms reaching to paddle -->
  <path d="M233,80 L210,90 M247,80 L270,90" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/>

  <!-- Paddle — extending both sides -->
  <path d="M190,92 L312,88" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
  <!-- Left blade — feathered, in water -->
  <path d="M190,92 Q183,96 184,103 Q188,108 195,106 Q200,101 196,94 Z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
  <!-- Right blade — in air, feathered different angle -->
  <path d="M312,88 Q320,82 322,75 Q318,70 311,72 Q306,77 308,86 Z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round" opacity="0.45"/>
  <!-- Drips from left blade -->
  <path d="M188,103 Q186,108 187,112 M194,106 Q193,111 194,115" stroke="currentColor" stroke-width="0.6" stroke-linecap="round" opacity="0.25"/>

  <!-- Distant island shore -->
  <path d="M0,55 Q30,48 60,50 Q90,46 120,40 Q150,34 180,36 Q220,38 260,34 Q300,30 340,36 Q360,40 380,38" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.25"/>
  <!-- Spruce hints on shore -->
  <path d="M120,40 L120,28 M140,36 L140,22 M160,36 L160,24 M180,36 L180,22 M200,34 L200,20 M220,34 L220,22" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.18"/>

</svg>
