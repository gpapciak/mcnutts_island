  <path d="M300,118 Q293,114 288,116 M300,118 Q307,114 312,116 M300,128 Q292,123 286,125 M300,128 Q308,123 314,125 M300,140 Q293,135 287,137 M300,140 Q307,135 313,137 M300,152 Q294,148 290,150 M300,152 Q306,148 310,150" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>

  <!-- Pencil resting on right page -->
