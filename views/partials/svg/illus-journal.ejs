  <circle cx="52" cy="140" r="2.5" stroke="currentColor" stroke-width="0.9" opacity="0.3"/>
  <circle cx="52" cy="190" r="2.5" stroke="currentColor" stroke-width="0.9" opacity="0.3"/>

