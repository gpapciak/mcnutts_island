<!-- Open field journal / notebook — naturalist sketch style -->
<svg class="svg-illustration svg-illustration--md svg-illustration--center" viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

  <!-- Book shadow -->
