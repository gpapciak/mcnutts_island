  <!-- Subheading underline -->
  <path d="M215,85 L260,82" stroke="currentColor" stroke-width="0.7" stroke-linecap="round" opacity="0.3"/>
  <!-- Body lines -->
  <path d="M215,102 L340,99 M215,115 L340,112 M215,128 L332,125 M215,141 L340,138 M215,154 L336,151 M215,167 L340,164 M215,180 L328,177" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.28"/>
